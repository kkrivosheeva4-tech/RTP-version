SECRET_KEY=replace-with-secure-value
DEBUG=False
LOG_LEVEL=INFO
ALLOWED_HOSTS=rtp3.test-ad.example,api.rtp3.test-ad.example

# Frontend origin in test contour
CORS_ALLOWED_ORIGINS=https://rtp3.test-ad.example
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOW_CREDENTIALS=True
CSRF_TRUSTED_ORIGINS=https://rtp3.test-ad.example

# Transport/security baseline for test AD contour
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
USE_X_FORWARDED_HOST=True
USE_X_FORWARDED_PORT=True
SECURE_PROXY_SSL_HEADER_ENABLED=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False
CSP_ENABLED=True
CSP_REPORT_ONLY=False
CSP_SCRIPT_SRC_EXTRA=https://cdn.jsdelivr.net,https://cdnjs.cloudflare.com
CSP_STYLE_SRC_EXTRA=
CSP_IMG_SRC_EXTRA=
CSP_FONT_SRC_EXTRA=
CSP_CONNECT_SRC_EXTRA=
CSP_WORKER_SRC_EXTRA=
CSP_MANIFEST_SRC_EXTRA=
CSP_MEDIA_SRC_EXTRA=
CSP_INCLUDE_UPGRADE_INSECURE_REQUESTS=True

AUTH_LOGIN_RATE=20/min
AUTH_2FA_RATE=30/min
AUTH_REFRESH_RATE=30/min
AUTH_LOGOUT_RATE=60/min

# Cookie refresh model only. Возврат refresh_token в body не используется.
AUTH_REFRESH_COOKIE_ENABLED=True
AUTH_RETURN_REFRESH_TOKEN_IN_BODY=False
AUTH_REFRESH_COOKIE_NAME=rtp3_refresh_token
AUTH_REFRESH_COOKIE_SECURE=True
AUTH_REFRESH_COOKIE_HTTPONLY=True
AUTH_REFRESH_COOKIE_SAMESITE=Lax
AUTH_REFRESH_COOKIE_PATH=/api/v1/auth/
# AUTH_REFRESH_COOKIE_DOMAIN=
AUTH_REFRESH_REQUIRE_CSRF=True
TOTP_SECRET_ENCRYPTION_KEY=replace-with-base64-fernet-key

# PostgreSQL-only profile for test contour
DB_ENGINE=postgresql
DB_NAME=rtp3
DB_USER=rtp3
DB_PASSWORD=rtp3
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=0
DB_CONNECT_TIMEOUT=10
DB_SSLMODE=prefer
# DB_SSLROOTCERT=
# DB_SSLCERT=
# DB_SSLKEY=

ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7
TWOFA_SESSION_LIFETIME_MINUTES=10
TOTP_ISSUER=Radar
