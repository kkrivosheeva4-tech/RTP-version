SECRET_KEY=replace-with-generated-secret
DEBUG=True
ENFORCE_ENV_SECURITY=False
LOG_LEVEL=INFO

# Local production-like HTTPS origin without reverse proxy.
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=https://127.0.0.1:8443,https://localhost:8443
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOW_CREDENTIALS=True
CSRF_TRUSTED_ORIGINS=https://127.0.0.1:8443,https://localhost:8443

# HTTPS local baseline without reverse proxy.
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
USE_X_FORWARDED_HOST=False
USE_X_FORWARDED_PORT=False
SECURE_PROXY_SSL_HEADER_ENABLED=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
CSP_ENABLED=True
CSP_REPORT_ONLY=False
CSP_SCRIPT_SRC_EXTRA=https://cdn.jsdelivr.net,https://cdnjs.cloudflare.com
CSP_STYLE_SRC_EXTRA=
CSP_IMG_SRC_EXTRA=
CSP_FONT_SRC_EXTRA=
CSP_CONNECT_SRC_EXTRA=
CSP_WORKER_SRC_EXTRA=
CSP_MANIFEST_SRC_EXTRA=
CSP_MEDIA_SRC_EXTRA=
CSP_INCLUDE_UPGRADE_INSECURE_REQUESTS=False

AUTH_LOGIN_RATE=20/min
AUTH_2FA_RATE=30/min
AUTH_REFRESH_RATE=30/min
AUTH_LOGOUT_RATE=60/min

# Cookie refresh model only. Возврат refresh_token в body не используется.
AUTH_REFRESH_COOKIE_ENABLED=True
AUTH_RETURN_REFRESH_TOKEN_IN_BODY=False
AUTH_REFRESH_COOKIE_NAME=rtp3_refresh_token
AUTH_REFRESH_COOKIE_SECURE=True
AUTH_REFRESH_COOKIE_HTTPONLY=True
AUTH_REFRESH_COOKIE_SAMESITE=Lax
AUTH_REFRESH_COOKIE_PATH=/api/v1/auth/
# AUTH_REFRESH_COOKIE_DOMAIN=
AUTH_REFRESH_REQUIRE_CSRF=True

# PostgreSQL runtime profile.
DB_ENGINE=postgresql
DB_NAME=rtp3
DB_USER=rtp3
DB_PASSWORD=rtp3
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=0
DB_CONNECT_TIMEOUT=10
DB_SSLMODE=prefer
# DB_SSLROOTCERT=
# DB_SSLCERT=
# DB_SSLKEY=

ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7
TWOFA_SESSION_LIFETIME_MINUTES=10
TOTP_ISSUER=Radar

# Script helpers for the local production-like contour.
LOCAL_PRODLIKE_ORIGIN=https://127.0.0.1:8443
LOCAL_PRODLIKE_BACKEND_BIND=127.0.0.1:8443
