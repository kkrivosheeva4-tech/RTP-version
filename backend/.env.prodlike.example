SECRET_KEY=replace-with-generated-secret
DEBUG=False
ENFORCE_ENV_SECURITY=True
LOG_LEVEL=INFO

# Local production-like hostname.
ALLOWED_HOSTS=rtp3.localhost,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://rtp3.localhost
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOW_CREDENTIALS=True
CSRF_TRUSTED_ORIGINS=https://rtp3.localhost

# HTTPS / proxy baseline.
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
USE_X_FORWARDED_HOST=True
USE_X_FORWARDED_PORT=True
SECURE_PROXY_SSL_HEADER_ENABLED=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
CSP_ENABLED=True
CSP_REPORT_ONLY=False

AUTH_LOGIN_RATE=20/min
AUTH_2FA_RATE=30/min
AUTH_REFRESH_RATE=30/min
AUTH_LOGOUT_RATE=60/min

# Cookie refresh model.
AUTH_REFRESH_COOKIE_ENABLED=True
AUTH_RETURN_REFRESH_TOKEN_IN_BODY=False
AUTH_REFRESH_COOKIE_NAME=rtp3_refresh_token
AUTH_REFRESH_COOKIE_SECURE=True
AUTH_REFRESH_COOKIE_HTTPONLY=True
AUTH_REFRESH_COOKIE_SAMESITE=Lax
AUTH_REFRESH_COOKIE_PATH=/api/v1/auth/
# AUTH_REFRESH_COOKIE_DOMAIN=
AUTH_REFRESH_REQUIRE_CSRF=True

# Let Django serve the built frontend so the local contour stays same-origin.
SERVE_FRONTEND_FROM_DJANGO=True
FRONTEND_DIST_DIR=../dist

# PostgreSQL runtime profile.
DB_ENGINE=postgresql
DB_NAME=rtp3
DB_USER=rtp3
DB_PASSWORD=rtp3
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=0
DB_CONNECT_TIMEOUT=10
DB_SSLMODE=prefer
# DB_SSLROOTCERT=
# DB_SSLCERT=
# DB_SSLKEY=

ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7
TWOFA_SESSION_LIFETIME_MINUTES=10
TOTP_ISSUER=Radar

# Script helpers for the local production-like contour.
LOCAL_PRODLIKE_HOST=rtp3.localhost
LOCAL_PRODLIKE_ORIGIN=https://rtp3.localhost
LOCAL_PRODLIKE_BACKEND_BIND=127.0.0.1:8000
LOCAL_PRODLIKE_BACKEND_UPSTREAM=127.0.0.1:8000
